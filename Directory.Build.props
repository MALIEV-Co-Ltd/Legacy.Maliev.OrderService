<Project>
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <MalievWorkspaceRoot Condition="'$(MalievWorkspaceRoot)' == ''">$(MSBuildThisFileDirectory)..</MalievWorkspaceRoot>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Update="Microsoft.EntityFrameworkCore" Version="10.0.4" />
    <PackageReference Update="Microsoft.EntityFrameworkCore.Relational" Version="10.0.4" />
    <PackageReference Update="Microsoft.EntityFrameworkCore.Abstractions" Version="10.0.4" />
  </ItemGroup>
</Project>
